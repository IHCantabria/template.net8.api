{
  "AllowedHosts": "#{HOST_API_DOMAIN}#",
  "Api": {
    "Address": "#{HOST_API_DOMAIN}#"
  },
  "Connections": {
    "AppDb": {
      "ConnectionString": "#{APP_DB_CONNECTION}#"
    }
  },
  "Cors": {
    "AllowedOrigins": "#{HOST_API_CORS_ALLOWED_ORIGINS}#"
  },
  "OpenTelemetry": {
    "IsLogActive": true,
    "IsMetricActive": false,
    "IsTraceActive": false,
    "LogEndpointUrl": "#{OPEN_TELEMETRY_ENDPOINT_LOG_URL}#",
    "ServiceName": "{PROJECT_NAMESPACE}"
  },
  "Swagger": {
    "ServerUrl": "#{HOST_API_URL}#"
  }
}
